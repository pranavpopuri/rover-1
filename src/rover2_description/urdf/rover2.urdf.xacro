<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rover2">

  <!-- Include macros -->
  <xacro:include filename="$(find rover2_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find rover2_description)/urdf/inertial_macros.xacro"/>

  <!-- ==================== PARAMETERS ==================== -->

  <!-- Wheel parameters (from Viam Rover 2 spec) -->
  <xacro:property name="wheel_radius" value="0.06065"/>      <!-- 121.3mm diameter / 2 -->
  <xacro:property name="wheel_width" value="0.03"/>          <!-- 30mm wheel width -->
  <xacro:property name="wheel_separation" value="0.356"/>    <!-- 356mm track width -->
  <xacro:property name="wheel_mass" value="0.2"/>            <!-- Estimated wheel mass -->

  <!-- Chassis parameters -->
  <xacro:property name="chassis_length" value="0.295"/>      <!-- 29.5cm -->
  <xacro:property name="chassis_width" value="0.22"/>        <!-- 22cm -->
  <xacro:property name="chassis_height" value="0.07"/>       <!-- 7cm -->
  <xacro:property name="chassis_mass" value="2.5"/>          <!-- Estimated total mass -->

  <!-- Chassis position relative to base_link (wheel axis center) -->
  <xacro:property name="chassis_x_offset" value="0.05"/>     <!-- Chassis center forward of wheel axis -->
  <xacro:property name="chassis_z_offset" value="0.02"/>     <!-- Chassis bottom above wheel axis -->

  <!-- Caster parameters -->
  <xacro:property name="caster_radius" value="0.025"/>       <!-- Small caster wheel -->
  <xacro:property name="caster_x_offset" value="0.12"/>      <!-- Caster in front of chassis -->
  <xacro:property name="caster_mass" value="0.1"/>

  <!-- Camera parameters -->
  <xacro:property name="camera_x" value="0.14"/>             <!-- Front of chassis -->
  <xacro:property name="camera_z" value="0.05"/>             <!-- Above chassis -->

  <!-- IMU parameters -->
  <xacro:property name="imu_x" value="0.0"/>
  <xacro:property name="imu_z" value="0.04"/>

  <!-- ==================== BASE LINK ==================== -->

  <!-- Base link at center of wheel axis (ground projection) -->
  <link name="base_link"/>

  <!-- Base footprint for navigation (on ground plane) -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 ${-wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CHASSIS ==================== -->

  <link name="chassis">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="${chassis_x_offset} 0 ${chassis_z_offset + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== WHEEL MACRO ==================== -->

  <xacro:macro name="wheel" params="prefix y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${y_reflect * wheel_separation/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <!-- Instantiate wheels -->
  <xacro:wheel prefix="left" y_reflect="1"/>
  <xacro:wheel prefix="right" y_reflect="-1"/>

  <!-- ==================== CASTER WHEEL ==================== -->

  <!-- Caster mount (allows rotation) -->
  <link name="caster_mount">
    <visual>
      <geometry>
        <cylinder radius="0.01" length="0.02"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.01" length="0.02"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.05" r="0.01" h="0.02"/>
  </link>

  <joint name="caster_mount_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_mount"/>
    <origin xyz="${chassis_length/2 - 0.02} 0 ${-chassis_height/2 - 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- Caster wheel (sphere approximation for better simulation) -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="caster_mount"/>
    <child link="caster_wheel"/>
    <origin xyz="0 0 ${-caster_radius - 0.01 - (wheel_radius - chassis_z_offset - chassis_height/2 - 0.01 - caster_radius)}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== IMU ==================== -->

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.01" x="0.02" y="0.02" z="0.005"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="chassis"/>
    <child link="imu_link"/>
    <origin xyz="${imu_x} 0 ${chassis_height/2 + 0.003}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CAMERA ==================== -->

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.06 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.06 0.02"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.05" x="0.02" y="0.06" z="0.02"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="chassis"/>
    <child link="camera_link"/>
    <origin xyz="${chassis_length/2 - 0.01} 0 ${chassis_height/2 + camera_z}" rpy="0 0 0"/>
  </joint>

  <!-- Camera optical frame (rotated per ROS convention: Z forward, X right, Y down) -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

</robot>
